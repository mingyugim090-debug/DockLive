# Backend environment example. Copy this file to .env and fill real values.
# This file is safe to commit because it contains no secrets.

OPENAI_API_KEY=sk-proj-your_real_key_here
FRONTEND_URL=https://your-app.vercel.app
MAX_PDF_SIZE_MB=20
MOCK_MODE=false
REDIS_URL=
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_DRAFT_MODEL=gpt-4o-mini
MAX_DRAFT_INPUT_LENGTH=60000
WORKFLOW_TTL_SECONDS=604800
