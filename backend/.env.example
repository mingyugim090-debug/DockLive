# Backend environment example. Copy to backend/.env and fill real values.
# Do not commit backend/.env.

AI_PROVIDER=openai

# OpenAI provider
OPENAI_API_KEY=sk-proj-your_real_key_here
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_DRAFT_MODEL=gpt-4o-mini

# Gemma provider through the hosted Gemini API.
# Set AI_PROVIDER=gemma and provide GEMINI_API_KEY to use these.
GEMINI_API_KEY=your_gemini_api_key_here
GEMMA_ANALYSIS_MODEL=gemma-4-26b-a4b-it
GEMMA_DRAFT_MODEL=gemma-4-31b-it

FRONTEND_URL=http://localhost:3000
MAX_PDF_SIZE_MB=20
MOCK_MODE=true

# Supabase is the target persistence/auth/storage platform for the Agent MVP.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_STORAGE_BUCKET=livedock-documents

# Temporary local/deployment fallback. Supabase should replace this for production workflows.
REDIS_URL=
WORKFLOW_TTL_SECONDS=604800

# HWPX export toolchain.
# In deployment, the Docker image can use the bundled backend/hwpx_toolchain.
# Locally, leave HWPX_SKILL_DIR empty to use the bundled toolchain, or point it
# at CODEX_HOME/skills/hwpx while developing the skill itself.
HWPX_EXPORT_ENABLED=true
HWPX_SKILL_DIR=
HWPX_TEMPLATE_DIR=

MAX_DRAFT_INPUT_LENGTH=60000
