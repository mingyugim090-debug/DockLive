# Frontend environment example. Copy to frontend/.env.local and fill real values.
# Do not commit frontend/.env.local.

NEXT_PUBLIC_API_URL=http://localhost:8000

# InsForge client-side values for the future authenticated/community workflow.
NEXT_PUBLIC_INSFORGE_BASE_URL=https://trgf5yzm.ap-southeast.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Server-only payment confirmation values for Next.js route handlers.
# Keep these out of client code and VCS.
INSFORGE_BASE_URL=https://trgf5yzm.ap-southeast.insforge.app
INSFORGE_API_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
